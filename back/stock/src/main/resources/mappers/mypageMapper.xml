<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  
  <mapper namespace="com.dk.project.mypage.model.dao.MypageMapper">
  
  	<insert id="uploadProfileImage">
  	
  	INSERT INTO TB_PROFILE (
			
			USER_NO,
			PROFILE_URL
	)
	VALUES (
			#{userNo},
			#{uploadedUrl}
		
	)
  	
  	</insert>
  
  
  	<select id="getProfileImage"
  			parameterType="com.dk.project.mypage.model.dto.ProfileDTO"
  			resultType="com.dk.project.mypage.model.dto.ProfileResponseDTO">
  	
  		SELECT
  				PROFILE_URL fileUrl
  		FROM
  				TB_PROFILE
  		WHERE
  				USER_NO = #{userNo}
  	
  	</select>
  	
  	
  	<update id="updateProfileImage">

		UPDATE
				TB_PROFILE
		SET
				PROFILE_URL = #{uploadedUrl}	
		WHERE
				USER_NO = #{userNo}		
  	
  	</update>
  	
  <!--	<delete id="deleteProfileImage"
  			parameterType="Long">
  	
  		DELETE
  				TB_PROFILE
  		WHERE
  				USER_NO = #{userNo}
  		
  	</delete>
  	-->

  
  
  
  </mapper>